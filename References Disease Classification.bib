	doi = {10.1109/IC2E365635.2025.11167850},
	abstract = {In medical research, it is critical task to predict cancer in its initial stages due to the growth of population. There is a requirement of a system that can predict the cancer in early stages because in later stages, sometimes it leads to death. This paper emphasizes on breast cancer prediction in its early stages. The initial phase of the help-seeking process, when the patient recognizes and categorizes the symptoms. It is the most crucial for women with breast cancer. The reduction in the survival rate in this disease are associated to symptoms appearing three months or more later. Machine Learning has become a buzzword nowadays for the predictions of distinct types of cancers. Because of improved survival from a combination of earlier detection, breast screening and better treatment, there has been a recent decline in the number of fatalities from breast cancer. This prediction minimizes the hospital visits in future and provides the people hassle free life. The purpose of this paper is to suggest efficient algorithms that predict the breast cancer efficiently. The popular algorithms such as random forest, k-nearest neighbor, na¨ıve bayes, and support vector machine have been applied on the popular Wisconsin dataset on breast cancer and offers good results in terms of performance metrics.},
	language = {en},
	urldate = {2026-03-11},
	booktitle = {2025 {IEEE} {International} {Conference} on {Computer}, {Electronics}, {Electrical} {Engineering} \&amp; their {Applications} ({IC2E3})},
	publisher = {IEEE},
	author = {Ahmed, Sara and Pundir, Meena and Goel, Paurav},
	month = may,
	year = {2025},
	pages = {1--6},
	file = {PDF:C\:\\Users\\ba09534\\Zotero\\storage\\983HZAFQ\\Ahmed et al. - 2025 - Breast Cancer Prediction Using Machine Learning Algorithm.pdf:application/pdf},
}

@article{jiang_deep_2024,
	title = {Deep learning applications in breast cancer histopathological imaging: diagnosis, treatment, and prognosis},
	volume = {26},
	issn = {1465-542X},
	shorttitle = {Deep learning applications in breast cancer histopathological imaging},
	url = {https://breast-cancer-research.biomedcentral.com/articles/10.1186/s13058-024-01895-6},
	doi = {10.1186/s13058-024-01895-6},
	abstract = {Breast cancer is the most common malignant tumor among women worldwide and remains one of the leading causes of death among women. Its incidence and mortality rates are continuously rising. In recent years, with the rapid advancement of deep learning (DL) technology, DL has demonstrated significant potential in breast cancer diagnosis, prognosis evaluation, and treatment response prediction. This paper reviews relevant research progress and applies DL models to image enhancement, segmentation, and classification based on large-scale datasets from TCGA and multiple centers. We employed foundational models such as ResNet50, Transformer, and Hover-net to investigate the performance of DL models in breast cancer diagnosis, treatment, and prognosis prediction. The results indicate that DL techniques have significantly improved diagnostic accuracy and efficiency, particularly in predicting breast cancer metastasis and clinical prognosis. Furthermore, the study emphasizes the crucial role of robust databases in developing highly generalizable models. Future research will focus on addressing challenges related to data management, model interpretability, and regulatory compliance, ultimately aiming to provide more precise clinical treatment and prognostic evaluation programs for breast cancer patients.},
	language = {en},
	number = {1},
	urldate = {2026-03-11},
	journal = {Breast Cancer Research},
	author = {Jiang, Bitao and Bao, Lingling and He, Songqin and Chen, Xiao and Jin, Zhihui and Ye, Yingquan},
	month = sep,
	year = {2024},
	pages = {137},
	file = {PDF:C\:\\Users\\ba09534\\Zotero\\storage\\735CJCD7\\Jiang et al. - 2024 - Deep learning applications in breast cancer histopathological imaging diagnosis, treatment, and pro.pdf:application/pdf},
}

